# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
POSTGRES_PORT=5432

# Database Admin
PGADMIN_DEFAULT_EMAIL=default@mail.com
PGADMIN_DEFAULT_PASSWORD=password

# Vector Embedding
VECTOR_EMBEDDING_DIMENSION=1024
COHERE_API_KEY=cohere-api-key # https://dashboard.cohere.com/api-keys
EMBEDDING_MODEL=embed-multilingual-v3.0

# Retrieval
RETRIEVAL_TOP_K=8

# Language Model
GROQ_API_KEY=groq-api-key # https://console.groq.com/keys
LLM_MODEL=openai/gpt-oss-20b

# Health: seconds between live Cohere/Groq probes on GET /health
HEALTH_PROVIDER_CACHE_TTL_SECONDS=300

# RQ: how many seconds to keep finished embedding jobs in Redis (-1 = forever)
EMBED_JOB_RESULT_TTL=-1

# Observability 
LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=langsmith-api-key
LANGSMITH_PROJECT=default-project