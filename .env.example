# Vector DB
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# Database Admin
PGADMIN_DEFAULT_EMAIL=default@mail.com
PGADMIN_DEFAULT_PASSWORD=password

# Vector Embedding
VECTOR_EMBEDDING_DIMENSION=1024
COHERE_API_KEY=cohere-api-key
EMBEDDING_MODEL=default-embedding-model

# Language Model
GROQ_API_KEY=groq-api-key
LLM_MODEL=default-llm-model

# Health: seconds between live Cohere/Groq probes on GET /health
HEALTH_PROVIDER_CACHE_TTL_SECONDS=300