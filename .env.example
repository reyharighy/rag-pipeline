# Job Queue
JOB_QUEUE_URL=redis://localhost:6379
JOB_QUEUE_RESULT_TTL=-1 # default -1 = forever, in seconds [optional]

# Database
DATABASE_USERNAME=defaultusername
DATABASE_PASSWORD=defaultpassword
DATABASE_NAME=defaultdatabasename

# Database Admin
DATABASE_ADMIN_EMAIL=default@email.com
DATABASE_ADMIN_PASSWORD=defaultpassword

# Vector Embedding
VECTOR_EMBEDDING_MODEL=embed-multilingual-v3.0 # default embed-multilingual-v3.0 [optional]
VECTOR_EMBEDDING_DIMENSION=1024 # default 1024 (for embed-multilingual-v3.0 - must match the model) [optional]
COHERE_API_KEY=cohere-api-key # https://dashboard.cohere.com/api-keys

# Retrieval
RETRIEVAL_TOP_K=8

# Language Model
GROQ_API_KEY=groq-api-key # https://console.groq.com/keys
LLM_MODEL=openai/gpt-oss-20b

# Health: seconds between live Cohere/Groq probes on GET /health
HEALTH_PROVIDER_CACHE_TTL_SECONDS=300

# Observability 
LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=langsmith-api-key
LANGSMITH_PROJECT=default-project